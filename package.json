{
  "name": "pi-extension-creator",
  "version": "0.2.0",
  "private": true,
  "license": "MIT",
  "description": "A pi.dev extension creator and validator for guiding LLM-driven extension workflows.",
  "type": "commonjs",
  "main": "dist/cli.js",
  "bin": {
    "pi-extension-creator": "dist/cli.js"
  },
  "pi": {
    "extensions": ["./src/extensions/extension-creator"],
    "prompts": ["./prompts"],
    "skills": ["./skills"]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "validate": "npm run build && node dist/cli.js validate",
    "validate:src": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "typescript": "^5.6.3"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*"
  }
}
